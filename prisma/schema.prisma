generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  PENDING
  DRAFTING
  EDITORIAL
  VOICE
  MEDIA
  FINAL_RENDER
  PUBLISHED
  FAILED
}

enum ScriptStatus {
  DRAFT
  APPROVED
  VOICE_GENERATED
  MEDIA_GENERATED
  RENDERED
  RENDERING
  FAILED
}

model WeeklyInquiry {
  id            String   @id @default(cuid())
  uaId          String   @unique // e.g., UA-20260202-1209
  theme         String
  thinking      String?
  reality       String?
  rant          String?
  nuclear       String?
  anythingElse  String?
  status        Status   @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  article       Article?
  scripts       VideoScript[]
  generationRuns GenerationRun[]
}

model Article {
  id              String        @id @default(cuid())
  weeklyInquiryId String        @unique
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  draftContent    String        @db.Text
  finalContent    String?       @db.Text
  approved        Boolean       @default(false)
  status          Status        @default(EDITORIAL) // Managed within the editorial stage
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model VideoScript {
  id              String        @id @default(cuid())
  weeklyInquiryId String
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  durationType    String        // 30s, 60s, 90s, 120s, 180s
  hook            String?       @db.Text
  script          String        @db.Text
  closingLine     String?       @db.Text
  
  audioUrl        String?       // Local path or URL
  videoUrl        String?       // Local path or URL
  approved        Boolean       @default(false)
  status          ScriptStatus  @default(DRAFT)
  visualPrompt    String?       @db.Text
  
  scenes          Scene[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([weeklyInquiryId, durationType])
}

model Scene {
  id              String        @id @default(cuid())
  videoScriptId   String
  videoScript     VideoScript   @relation(fields: [videoScriptId], references: [id], onDelete: Cascade)
  
  index           Int           // Position in video
  type            String        // VIDEO, IMAGE
  prompt          String        @db.Text
  scriptSegment   String?       @db.Text // The part of the script read during this scene
  duration        Float
  assetUrl        String?       // Local path or URL
  status          String        @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Settings {
  id              String        @id @default("global")
  geminiApiKey    String?
  falApiKey       String?
  elevenLabsApiKey String?
  substackUrl     String?
}

model Prompt {
  id        String   @id @default(cuid())
  key       String   // e.g., 'SUBSTACK_STAGE_1', 'SUBSTACK_STAGE_2'
  name      String?
  stage     Int      @default(1)
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GenerationRun {
  id              String        @id @default(cuid())
  weeklyInquiryId String
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  mode            String        // STANDARD, COMPARE
  
  // Stage 1 Info
  stage1Model     String
  stage1Provider  String
  stage1Prompt    String?       @db.Text
  stage1Output    String?       @db.Text // Spine JSON
  
  // Results
  outputs         GenerationOutput[]
  
  status          String        @default("SUCCESS")
  error           String?       @db.Text
  
  createdAt       DateTime      @default(now())
}

model GenerationOutput {
  id              String        @id @default(cuid())
  runId           String
  run             GenerationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  
  model           String
  provider        String
  prompt          String?       @db.Text
  content         String        @db.Text // Article Markdown
  
  tokensUsed      Int?
  costEstimate    Float?
  
  createdAt       DateTime      @default(now())
}
