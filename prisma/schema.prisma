generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  PENDING
  DRAFTING
  EDITORIAL
  VOICE
  MEDIA
  FINAL_RENDER
  PUBLISHED
  FAILED
}

enum ScriptStatus {
  DRAFT
  APPROVED
  VOICE_GENERATED
  MEDIA_GENERATED
  RENDERED
  RENDERING
  FAILED
}

model WeeklyInquiry {
  id            String   @id @default(cuid())
  uaId          String   @unique // e.g., UA-20260202-1209
  theme         String
  thinking      String?
  reality       String?
  rant          String?
  nuclear       String?
  anythingElse  String?
  status        Status   @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  article       Article?
  scripts       VideoScript[]
  generationRuns GenerationRun[]
  
  // Backwards compatibility/generic link
  driveOutputs  DriveOutput[]
  assets        OutputAsset[]
  textPosts     TextPost[]
}

model TextPost {
  id              String        @id @default(cuid())
  uaId            String        @unique // e.g., UA-POST-20260208-01
  weeklyInquiryId String
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  runId           String?
  run             GenerationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  index           Int           // 0-4 for the 5 posts
  title           String?
  content         String        @db.Text
  researchPackData String?      @db.Text // JSON string of research used for this post
  
  status          Status        @default(EDITORIAL)
  approved        Boolean       @default(false)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  driveOutputs    DriveOutput[]
  assets          OutputAsset[]
}

model Article {
  id              String        @id @default(cuid())
  weeklyInquiryId String        @unique
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  rawOutput       String?       @db.Text
  draftContent    String        @db.Text // Sanitized output
  finalContent    String?       @db.Text // Human edited
  researchPackData String?      @db.Text // JSON string of research used for this article
  validationReport String?      @db.Text // JSON string
  
  approved        Boolean       @default(false)
  status          Status        @default(EDITORIAL)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  driveOutputs    DriveOutput[]
  assets          OutputAsset[]
}

model VideoScript {
  id              String        @id @default(cuid())
  weeklyInquiryId String
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  durationType    String        // 30s, 60s, 90s, 120s, 180s
  hook            String?       @db.Text
  script          String        @db.Text
  closingLine     String?       @db.Text
  
  audioUrl          String?       // Local path or URL
  actualAudioDuration Float?       // Probed duration from FFmpeg
  videoUrl          String?       // Local path or URL
  aspectRatio     String        @default("1:1") // 1:1, 9:16
  approved        Boolean       @default(false)
  status          ScriptStatus  @default(DRAFT)
  visualPrompt    String?       @db.Text
  
  scenes          Scene[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  driveOutputs    DriveOutput[]
  assets          OutputAsset[]

  @@unique([weeklyInquiryId, durationType])
}

model Scene {
  id              String        @id @default(cuid())
  videoScriptId   String
  videoScript     VideoScript   @relation(fields: [videoScriptId], references: [id], onDelete: Cascade)
  
  index           Int           // Position in video
  type            String        // VIDEO, IMAGE
  prompt          String        @db.Text
  scriptSegment   String?       @db.Text // The part of the script read during this scene
  duration        Float
  assetUrl        String?       // Local path or URL
  approved        Boolean       @default(false)
  status          String        @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Settings {
  id              String        @id @default("global")
  geminiApiKey    String?
  falApiKey       String?
  elevenLabsApiKey String?
  substackUrl     String?
}

model Prompt {
  id        String   @id @default(cuid())
  key       String   // e.g., 'SUBSTACK_STAGE_1', 'SUBSTACK_STAGE_2'
  name      String?
  stage     Int      @default(1)
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GenerationRun {
  id              String        @id @default(cuid())
  weeklyInquiryId String
  weeklyInquiry   WeeklyInquiry @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  
  mode            String        // STANDARD, COMPARE
  
  // Stage 1 Info
  stage1Model     String
  stage1Provider  String
  stage1Prompt    String?       @db.Text
  stage1Output    String?       @db.Text // Spine JSON
  
  // Results
  outputs         GenerationOutput[]
  textPosts       TextPost[]
  
  status          String        @default("SUCCESS")
  error           String?       @db.Text
  
  createdAt       DateTime      @default(now())
}

model GenerationOutput {
  id              String        @id @default(cuid())
  runId           String
  run             GenerationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  
  model           String
  provider        String
  prompt          String?       @db.Text
  content         String        @db.Text // Article Markdown
  
  tokensUsed      Int?
  costEstimate    Float?
  
  createdAt       DateTime @default(now())
}

model DriveOutput {
  id                String   @id @default(cuid())
  driveFileId       String   @unique
  driveWebViewLink  String
  driveDownloadLink String?
  fileType          String   // AUDIO, VIDEO, TEXT
  fileName          String
  renderId          String   // e.g., scriptId or uaId
  createdAt         DateTime @default(now())
  
  // Relations
  videoScriptId     String?
  videoScript       VideoScript? @relation(fields: [videoScriptId], references: [id], onDelete: Cascade)
  articleId         String?
  article           Article?     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  weeklyInquiryId   String?
  weeklyInquiry     WeeklyInquiry? @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  textPostId        String?
  textPost          TextPost?    @relation(fields: [textPostId], references: [id], onDelete: Cascade)
}

model OutputAsset {
  id                String   @id @default(cuid())
  provider          String   // drive | supabase
  kind              String   // AUDIO | VIDEO | TEXT | CAPTIONS | IMAGE
  fileName          String
  
  // Supabase specific
  bucket            String?
  objectKey         String?
  
  // Drive specific
  driveFileId       String?  @unique
  driveWebViewLink  String?
  driveDownloadLink String?
  
  // Generic
  publicUrl         String?
  renderId          String   // e.g., scriptId or uaId
  createdAt         DateTime @default(now())

  // Relations
  videoScriptId     String?
  videoScript       VideoScript? @relation(fields: [videoScriptId], references: [id], onDelete: Cascade)
  articleId         String?
  article           Article?     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  weeklyInquiryId   String?
  weeklyInquiry     WeeklyInquiry? @relation(fields: [weeklyInquiryId], references: [id], onDelete: Cascade)
  textPostId        String?
  textPost          TextPost?    @relation(fields: [textPostId], references: [id], onDelete: Cascade)
}
